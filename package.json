		"semver": "^7.8.1",
		"tsx": "^4.19.3",
		"turbo": "^2.5.6",
		"typescript": "5.8.3"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,md}": [
			"prettier --write"
		]
	},
